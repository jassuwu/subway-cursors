{
  "name": "subway-cursors",
  "displayName": "subway cursors",
  "description": "subway surfers in cursor — runs while the AI is thinking, hard-pauses the moment it's done.",
  "publisher": "jassuwu",
  "author": "jassuwu",
  "license": "MIT",
  "version": "0.1.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/jassuwu/subway-cursors"
  },
  "bugs": {
    "url": "https://github.com/jassuwu/subway-cursors/issues"
  },
  "homepage": "https://github.com/jassuwu/subway-cursors#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["cursor", "subway-surfers", "brainrot", "ai", "hooks"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "subway-cursors.toggle", "title": "Subway: Toggle Game Panel" },
      { "command": "subway-cursors.resume", "title": "Subway: Resume" },
      { "command": "subway-cursors.pause", "title": "Subway: Pause" },
      { "command": "subway-cursors.installHooks", "title": "Subway: Install Cursor Hooks" },
      { "command": "subway-cursors.uninstallHooks", "title": "Subway: Uninstall Cursor Hooks" }
    ],
    "keybindings": [
      { "command": "subway-cursors.toggle", "key": "cmd+shift+g", "mac": "cmd+shift+g" }
    ],
    "configuration": {
      "title": "Subway Cursors",
      "properties": {
        "subwayCursors.viewColumn": {
          "type": "string",
          "enum": ["Beside", "One", "Two", "Active"],
          "default": "Beside",
          "description": "Where the game panel opens."
        },
        "subwayCursors.returnFocusToChat": {
          "type": "boolean",
          "default": true,
          "description": "After the AI finishes, return keyboard focus to the chat input."
        },
        "subwayCursors.autoPanelOnFirstPrompt": {
          "type": "boolean",
          "default": true,
          "description": "Open the game panel automatically the first time you submit a chat prompt."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
